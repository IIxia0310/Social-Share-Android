<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 主内容区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 顶部导航栏 -->
        <LinearLayout
            android:id="@+id/top_navigation_layout"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:background="#3F51B5"
            android:gravity="center_vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp">

            <!-- 侧边栏开关按钮 -->
            <ImageView
                android:id="@+id/sidebar_toggle"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:clickable="true"
                android:contentDescription="侧边栏开关"
                android:src="@drawable/toolbar_1" />

            <TextView
                android:id="@+id/app_name_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="生活分享APP管理员端"
                android:textColor="#ffffff"
                android:textSize="18sp" />


            <ImageView
                android:id="@+id/user_info_image"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginLeft="130dp"
                android:src="@drawable/toolbar_4" />

        </LinearLayout>

        <!-- 内容展示区域 -->
        <FrameLayout
            android:id="@+id/content_frame_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>

    <!-- 左侧边栏 -->
    <LinearLayout
        android:id="@+id/left_menu_layout"
        android:layout_width="180dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#f0f0f0"
        android:layout_gravity="start">

        <!-- 管理员信息区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="#3F51B5"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="bottom">



            <!-- 管理员信息 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="管理员: "
                    android:textColor="#ffffff"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/admin_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="admin123"
                    android:textColor="#ffffff"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>


        </LinearLayout>

        <!-- 菜单标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="功能菜单"
            android:gravity="center"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- 用户管理菜单项 -->
        <LinearLayout
            android:id="@+id/user_item"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="16dp"
            android:onClick="userManagementClick">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/fragment_5"
                android:layout_marginRight="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="用户管理"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- 内容管理菜单项 -->
        <LinearLayout
            android:id="@+id/note_item"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="16dp"
            android:onClick="contentManagementClick">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/fragment_1"
                android:layout_marginRight="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="内容管理"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- 系统设置菜单项 -->
        <LinearLayout
            android:id="@+id/message_item"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="16dp"
            android:onClick="systemSettingsClick">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/fragment_4"
                android:layout_marginRight="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="查看留言"
                android:textSize="16sp" />
        </LinearLayout>

