<!-- item_chat.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp">

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/MessageItem_Image"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_marginTop="1dp"
        android:src="@drawable/image_portrait" />

    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/MessageItem_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="用户"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/MessageItem_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="内容"
            android:layout_marginTop="1dp"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/MessageItem_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2023-01-19 09:45:50"
            android:textSize="12sp"
            android:layout_marginTop="1dp"
            android:textColor="@color/colorLightGrey" />

    </LinearLayout>

    <!-- 添加显示未读信息的小红圆点 -->
    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="20dp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp">

        <TextView
            android:id="@+id/unread_count_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/dot_red"
            android:text="  3  "
            android:padding="1dp"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:gravity="center" />

    </RelativeLayout>


</LinearLayout>