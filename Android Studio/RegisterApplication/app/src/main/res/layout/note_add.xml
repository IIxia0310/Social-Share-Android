<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/background1_pink_blue"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="5dp"
    android:id="@+id/Theme_NoteAdd"
    tools:context=".View.NoteAdd">


    <androidx.appcompat.widget.Toolbar
        android:id="@+id/Toolbar_Add"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/Add_button_interest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/CustomButtonStyle3"
            android:text="去选择类型" />

        <TextView
            android:id="@+id/Add_interest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15dp"
            android:text="xxxxxx" />
    </LinearLayout>

    <!--图片-->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/image_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"/>

    </HorizontalScrollView>

    <!--视频-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <VideoView
            android:id="@+id/video_container"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="1dp"
            android:visibility="gone"/>
    </LinearLayout>



    <Button
        android:id="@+id/Add_button_image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        style="@style/CustomButtonStyle3"
        android:text="去相册选择" />


    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:orientation="vertical">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/border_shape">
                <EditText
                    android:id="@+id/Add_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#111111"
                    android:inputType="text"
                    android:hint="添加标题"
                    android:maxLength="20" />

                <EditText
                    android:id="@+id/Add_content"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:textColor="#111111"
                    android:inputType="textMultiLine"
                    android:hint="添加内容"
                    android:gravity="top|start" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/Add_drawer1_visibility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/Add_left1_visibility"
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="0"
                    android:src="@drawable/add_visible_botton1" />

                <TextView
                    android:id="@+id/Add_middle1_visibility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="公开可见"
                    android:textSize="16sp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/Add_right1_visibility"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_weight="0"
                    android:src="@drawable/ic_all2" />
            </LinearLayout>
        </androidx.appcompat.widget.LinearLayoutCompat>


    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="6dp"
        android:orientation="horizontal">
        <!-- 子 LinearLayout 内容 -->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/Add_bottom_draft"
                style="@style/CustomButtonStyle2"
                android:layout_width="match_parent"
                android:layout_height="29dp"
                android:drawableLeft="@drawable/add_button1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="存草稿"
                android:layout_marginStart="4dp"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <Button
                android:id="@+id/Add_bottom_preview"
                style="@style/CustomButtonStyle2"
                android:layout_width="50dp"
                android:layout_height="29dp"
                android:layout_marginStart="10dp"
                android:drawableLeft="@drawable/add_button2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="预览"
                android:layout_marginStart="19dp"
                android:textSize="15sp" />
        </LinearLayout>

        <!--发布笔记按钮 -->
        <Button
            android:id="@+id/Add_bottom_postNotes"
            style="@style/CustomButtonStyle3"
            android:layout_width="270dp"
            android:layout_height="45dp"
            android:layout_marginStart="10dp"
            android:layout_gravity="end"
            android:text="发布笔记" />

    </LinearLayout>
</androidx.appcompat.widget.LinearLayoutCompat>